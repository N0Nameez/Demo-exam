<Window x:Class="retail.View.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:retail.View"
       Title="Заказ" Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Товар:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxProduct" Margin="0,0,0,15"
                          DisplayMemberPath="ProductName"
                          SelectedValuePath="Article"/>

                <TextBlock Text="Количество:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtQuantity" Margin="0,0,0,15"
                         PreviewTextInput="NumberValidation"/>

                <TextBlock Text="Дата заказа:" Margin="0,0,0,5" FontWeight="Bold"/>
                <DatePicker x:Name="dpOrderDate" Margin="0,0,0,15"/>

                <TextBlock Text="Дата доставки:" Margin="0,0,0,5" FontWeight="Bold"/>
                <DatePicker x:Name="dpDeliveryDate" Margin="0,0,0,15"/>

                <TextBlock Text="Пункт выдачи:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxPickupPoint" Margin="0,0,0,15"
                          DisplayMemberPath="Address"
                          SelectedValuePath="PointId"/>

                <TextBlock Text="Клиент:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxCustomer" Margin="0,0,0,15"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="UserId"/>

                <TextBlock Text="Код выдачи:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtPickupCode" Margin="0,0,0,15"
                         PreviewTextInput="NumberValidation"/>

                <TextBlock Text="Статус:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxStatus" Margin="0,0,0,15">
                    <ComboBoxItem Content="В обработке"/>
                    <ComboBoxItem Content="Готов к выдаче"/>
                    <ComboBoxItem Content="Выдан"/>
                    <ComboBoxItem Content="Отменён"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Height="35" 
                    Margin="0,0,10,0" Click="Btn_Save_Click"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Click="Btn_Cancel_Click"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
        </StackPanel>
    </Grid>
</Window>