<Window x:Class="retail.Catalog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:retail"
        xmlns:card="clr-namespace:retail.View"
        xmlns:conv="clr-namespace:retail.Converters"
        xmlns:sys="clr-namespace:System.Runtime.Remoting;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Каталог товаров" Height="450" Width="800">

    <Window.Resources>
        <conv:BlobToImageConverter x:Key="BlobToImageConverter"/>
        <conv:DiscountGreaterThanConverter x:Key="DiscountGreaterThanConverter"/>
        <conv:IsZeroConverter x:Key="IsZeroConverter"/>
        <conv:PriceWithDiscountMultiConverter x:Key="PriceWithDiscountMultiConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="8">
            <TextBlock x:Name="lblUserFullName" DockPanel.Dock="Right" 
                   FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button x:Name="btnLogout" Content="Выход" DockPanel.Dock="Right" 
                Width="80" Height="28" Click="Btn_Logout_Click"/>
        </DockPanel>

        <TabControl Grid.Row="1">

            <!--Вкладка с товарами для всех пользователей-->
            <TabItem Header="Товары">
                <TabItem.Content>
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!--Сортировка для менеджера-->
                        <Grid Grid.ColumnSpan="3"
                      Height="75"
                      x:Name="sort_grid"
                      Visibility="Collapsed" >

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Поиск:"
                   Margin="5"/>

                            <TextBox Margin="5"
                             x:Name="txtSearch" 
                             Grid.Row="1"
                             TextChanged="txtSearch_TextChanged"/>

                            <ComboBox Margin="5"
                              x:Name="sort_cbx"
                              Grid.RowSpan="2"
                              Grid.Column="1"
                              SelectionChanged="sort_cbx_SelectionChanged">
                                <ComboBoxItem Content="Цена по возрастанию"/>
                                <ComboBoxItem Content="Цена по убыванию"/>
                                <ComboBoxItem Content="Количество по возрастанию"/>
                                <ComboBoxItem Content="Количество по убыванию"/>
                            </ComboBox>

                            <ComboBox Margin="5"
                              x:Name="filter_cbx"
                              Grid.RowSpan="2"
                              Grid.Column="2"
                              SelectionChanged="filter_cbx_SelectionChanged"/>

                            <Button Margin="5"
                            Visibility="Collapsed"
                            x:Name="add_btn"
                            Content="Добавить"
                            Grid.Column="3"
                            Grid.RowSpan="2"
                            Click="Btn_AddProduct_Click"/>
                        </Grid>

                        

                        <ListView Grid.Row="1" Grid.RowSpan="2"
                          x:Name="product_lv"
                          Grid.ColumnSpan="3"
                          ItemsSource="{Binding ProductList}">
                            
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDiscount, Converter={StaticResource DiscountGreaterThanConverter}}" Value="True">
                                            <Setter Property="Background" Value="#2E8B57"/>
                                        </DataTrigger>
                                        
                                    </Style.Triggers>

                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Редактировать" Click="MenuItem_EditProduct_Click"/>
                                    <MenuItem Header="Удалить" Click="MenuItem_DeleteProduct_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <card:ProductCard/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <TextBlock Text="Товар не найден"
                                   Visibility="Collapsed"
                                   Foreground="Black"
                                   FontSize="32"
                                   x:Name="unknown_tbx"
                                   Grid.ColumnSpan="3"
                                   Grid.RowSpan="2" Grid.Row="1"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </TabItem.Content>
            </TabItem>

            <!--Вкладка заказов для администратора-->
            <TabItem Header="Заказы"
             Visibility="Collapsed"
             x:Name="Order_tab">
                <TabItem.Content>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Кнопка добавления заказа -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                            <Button Content="Добавить заказ" Width="120" Height="35"
                    Click="Btn_AddOrder_Click"/>
                        </StackPanel>

                        <!--Вывод заказов-->
                        <ListView Grid.Row="1" Grid.RowSpan="2" 
                          Grid.ColumnSpan="3"
                          x:Name="orders_lv"
                          ItemsSource="{Binding OrderList}">

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Редактировать" Click="MenuItem_EditOrder_Click"/>
                                    <MenuItem Header="Удалить" Click="MenuItem_DeleteOrder_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <card:OrderCard/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem.Content>
            </TabItem>
        </TabControl>
    </Grid>

</Window>
