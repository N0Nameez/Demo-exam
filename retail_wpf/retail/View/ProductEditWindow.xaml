<Window x:Class="retail.View.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:retail.View"
        mc:Ignorable="d"
        Title="Товар" Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Артикул:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtArticle" Margin="0,0,0,15" 
                         MaxLength="20"
                         IsEnabled="{Binding IsNew, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="Название товара:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtProductName" Margin="0,0,0,15" MaxLength="100"/>

                <TextBlock Text="Единица измерения:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxUnit" Margin="0,0,0,15" IsEditable="True">
                    <ComboBoxItem Content="шт."/>
                    <ComboBoxItem Content="кг"/>
                    <ComboBoxItem Content="г"/>
                    <ComboBoxItem Content="л"/>
                    <ComboBoxItem Content="мл"/>
                    <ComboBoxItem Content="м"/>
                    <ComboBoxItem Content="см"/>
                    <ComboBoxItem Content="уп."/>
                </ComboBox>

                <TextBlock Text="Категория:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxCategory" Margin="0,0,0,15"
                          DisplayMemberPath="CategoryName"
                          SelectedValuePath="CategoryId"/>

                <TextBlock Text="Производитель:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxManufacturer" Margin="0,0,0,15"
                          DisplayMemberPath="ManufacturerName"
                          SelectedValuePath="ManufacturerId"/>

                <TextBlock Text="Поставщик:" Margin="0,0,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="cbxSupplier" Margin="0,0,0,15"
                          DisplayMemberPath="SupplierName"
                          SelectedValuePath="SupplierId"/>

                <TextBlock Text="Цена (₽):" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtPrice" Margin="0,0,0,15"
                         PreviewTextInput="NumberValidation"/>

                <TextBlock Text="Количество на складе:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtStockQuantity" Margin="0,0,0,15"
                         PreviewTextInput="NumberValidation"/>

                <TextBlock Text="Скидка (%):" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtDiscount" Margin="0,0,0,15"
                         PreviewTextInput="NumberValidation"/>

                <TextBlock Text="Описание:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtDescription" Margin="0,0,0,15"
                         Height="80" TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"/>

                <TextBlock Text="Фото товара:" Margin="0,0,0,5" FontWeight="Bold"/>
                <Image x:Name="imgPreview" Height="150" Width="150" 
                       Margin="0,0,0,15" Stretch="Uniform"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="Выбрать фото" Width="120" Click="Btn_SelectPhoto_Click"/>
                    <Button Content="Удалить фото" Width="120" Margin="10,0,0,0" 
                            Click="Btn_RemovePhoto_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Height="35" 
                    Margin="0,0,10,0" Click="Btn_Save_Click"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Click="Btn_Cancel_Click"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
        </StackPanel>
    </Grid>
</Window>