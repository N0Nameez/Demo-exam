<Window x:Class="retail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:retail"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="1"
                   FontSize="24"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Text="Авторизация"/>

        <TextBlock Grid.Row="1" Grid.Column="1"
                   Text="Логин:"/>
        <TextBox x:Name="Login_TBX"
                 Grid.Row="2" Grid.Column="1"
                 Height="35"/>

        <TextBlock Grid.Row="4" Grid.Column="1"
           Text="Пароль:"/>
        <TextBox x:Name="Pass_TBX"
                 Grid.Row="5" Grid.Column="1"
                 Height="35"/>
        
        <Button x:Name="Auth_BTN"
                Grid.Row="7" Grid.Column="1" 
                Height="35" Content="Войти" Click="Auth_BTN_Click"/>
        
        <Button x:Name="Guest_BTN"
                Grid.Row="9" Grid.Column="1" 
                Height="35" Content="Гость" Click="Guest_BTN_Click"/>
    </Grid>
</Window>
