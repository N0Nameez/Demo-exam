<UserControl x:Class="retail.View.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:retail.View"
             xmlns:conv="clr-namespace:retail.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             MinHeight="100"
             Height="Auto" Width="Auto">

    <UserControl.Resources>
        <conv:BlobToImageConverter x:Key="BlobToImageConverter"/>
        <conv:DiscountGreaterThanConverter x:Key="DiscountGreaterThanConverter"/>
        <conv:PriceWithDiscountMultiConverter x:Key="PriceWithDiscountMultiConverter"/>
        <conv:IsZeroConverter x:Key="IsZeroConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <Image Margin="5" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center"
       Source="{Binding Photo}"/>

        <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding CategoryAndName}"
                       Margin="5"/>
            
            <TextBlock Text="{Binding Description, StringFormat=Описание товара: {0}}"
                       Margin="5"/>

            <TextBlock Text="{Binding Manufacturer.ManufacturerName, StringFormat=Производитель: {0}}"
                       Margin="5"/>

            <TextBlock Text="{Binding Supplier.SupplierName, StringFormat=Поставщик: {0}}"
                       Margin="5"/>

            <!-- Старую цену (перечёркнутая) -->
            <TextBlock Text="{Binding Price, StringFormat={}{0:N2} ₽}" TextDecorations="Strikethrough" Foreground="Red" Margin="5,0,0,0">
                <TextBlock.Visibility>
                    <Binding Path="CurrentDiscount" Converter="{StaticResource DiscountGreaterThanConverter}"/>
                </TextBlock.Visibility>
            </TextBlock>

            <!-- Итоговая цена с учётом скидки -->
            <TextBlock Margin="8,0,0,0" FontWeight="Bold">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource PriceWithDiscountMultiConverter}">
                        <Binding Path="Price"/>
                        <Binding Path="CurrentDiscount"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <TextBlock Text="{Binding Unit, StringFormat=Единица измерения: {0}}"
                       Margin="5"/>

            <TextBlock Text="{Binding StockQuantity, StringFormat=Количество на складе: {0}}"
                       Margin="5">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StockQuantity, Converter={StaticResource IsZeroConverter}}" Value="True">
                                <Setter Property="Foreground" Value="LightBlue"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Column="2"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Text="{Binding DiscountPercent, StringFormat=Действующая скидка: {0:P0}}"/>
    </Grid>
</UserControl>
